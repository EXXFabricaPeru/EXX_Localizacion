<Page x:Class="exxis_localizacion.PaginaParams"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:exxis_localizacion"
      xmlns:util="clr-namespace:exxis_localizacion.util"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PaginaParams">
    <Grid Background="White" >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="10"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="10"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Grid.Column="1" Grid.Row="1" HorizontalAlignment="Right">
            <TextBlock Text="Conectado a " FontSize="12"  TextAlignment="Right" VerticalAlignment="Center"></TextBlock>
            <TextBlock Name="lblSociedad" Text="{Binding NombreSociedad, Mode=OneWay}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"></TextBlock>
        </StackPanel>
        <TabControl Name="tabPaquetes" ItemsSource="{Binding ListaPaquetes}" Grid.Row="3" Grid.Column="1" >
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="Header" Value="{Binding Path=Nombre}" />
                </Style>
            </TabControl.ItemContainerStyle>
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <!--<local:ControlPaquete Paquete="{Binding}"/>-->
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Grid.Row="5" Grid.Column="1">
            <Button Name="btnIniciar" Width="90" Click="Button_Click_1" IsEnabled="{Binding Listo}">Continuar</Button>
        </StackPanel>
    </Grid>
</Page>
