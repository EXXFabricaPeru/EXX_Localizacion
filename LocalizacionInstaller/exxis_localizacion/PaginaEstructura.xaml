<Page x:Class="exxis_localizacion.PaginaEstructura"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:exxis_localizacion"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Conexión">

    <Grid>
        <Grid.ColumnDefinitions >
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="10"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="10"/>
        </Grid.RowDefinitions>
        <Image Grid.Column="0" Grid.Row="0" Grid.RowSpan="10" Source="/exxis_localizacion;component/resources/imgs/sidepanel.jpg" Stretch="UniformToFill"></Image>
        <TextBlock Text="Localización Exxis Perú" Grid.Row="1" Grid.Column="2" FontSize="25" Grid.ColumnSpan="3"/>
        <TextBlock Text="Elija una opción para iniciar:" Grid.Row="3" Grid.Column="3" Grid.ColumnSpan="2"/>
        <RadioButton Name="rbtnUIConn" GroupName="rbtnTipoConn" Grid.Row="5" Grid.Column="3" VerticalAlignment="Center" IsChecked="True">Conectarse usando cliente SAP Business One</RadioButton>
        <RadioButton Name="rbtnDIConn" GroupName="rbtnTipoConn" Grid.Row="6" Grid.Column="3" VerticalAlignment="Center" IsEnabled="False">Conectarse usando credenciales de acceso</RadioButton>
        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Grid.Row="8" Grid.Column="2" Grid.ColumnSpan="3">
            <Button Name="btnContinuar" Width="90" Click="btnContinuar_Click">Iniciar</Button>
        </StackPanel>
    </Grid>
</Page>

