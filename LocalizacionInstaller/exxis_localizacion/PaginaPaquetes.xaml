<Page x:Class="exxis_localizacion.PaginaPaquetes"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:exxis_localizacion"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PaginaPaquetes">
    <Grid Background="White">
        <Grid.ColumnDefinitions >
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="10"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="10"/>
        </Grid.RowDefinitions>
        <Image Grid.Column="0" Grid.Row="0" Grid.RowSpan="10" Source="/exxis_localizacion;component/resources/imgs/sidepanel.jpg" Stretch="UniformToFill"></Image>
        <TextBlock Text="Selección de paquetes" Grid.Row="1" Grid.Column="2" FontSize="25" Grid.ColumnSpan="3"/>
        <StackPanel Orientation="Horizontal" Grid.Column="3" Grid.Row="2" HorizontalAlignment="Right">
            <TextBlock Text="Conectado a " FontSize="12"  TextAlignment="Right" VerticalAlignment="Center"></TextBlock>
            <TextBlock Name="lblSociedad" Text="{Binding NombreSociedad, Mode=OneWay}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"></TextBlock>
        </StackPanel>
        <TextBlock Text="Elija los paquetes a instalar" Grid.Row="4" Grid.Column="3" Grid.ColumnSpan="1"/>
        <DataGrid Grid.Row="5" Grid.Column="3" AutoGenerateColumns="False" ItemsSource="{Binding ListaPaquetes}"
                              CanUserAddRows="False" HeadersVisibility="Column" CanUserDeleteRows="False" 
                              CanUserReorderColumns="False" CanUserSortColumns="False">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Binding="{Binding Check}" Header="Check"/>
                <DataGridTextColumn Binding="{Binding Nombre}" IsReadOnly="true" Header="Nombre"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Grid.Row="8" Grid.Column="2" Grid.ColumnSpan="3">
            <Button Name="btnContinuar" Width="90" Click="btnContinuar_Click">Continuar</Button>
        </StackPanel>
    </Grid>
</Page>
